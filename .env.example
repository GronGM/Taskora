# Local MVP defaults.
APP_NAME=Taskora
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# Production checklist:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://example.com

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Local MVP uses SQLite. Future PostgreSQL settings:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=taskora
# DB_USERNAME=taskora
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Order files are private on the local disk. Public storage is reserved for future avatars/images.
# Future S3-compatible storage:
# FILESYSTEM_DISK=s3
QUEUE_CONNECTION=sync
# Future async queue:
# QUEUE_CONNECTION=database
# QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# S3 is not used in the MVP.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

BETA_ACCESS_ENABLED=false
BETA_ACCESS_PASSWORD=
BETA_ACCESS_COOKIE_NAME=taskora_beta_access

TASKORA_PLATFORM_FEE_PERCENT=15
TASKORA_CONTACT_GUARD_ENABLED=true
TASKORA_MODERATION_QUEUE_ENABLED=true
TASKORA_PAYMENTS_MODE=stub
PAYMENT_PROVIDER=stub
PAYMENT_PROVIDER_MODE=stub
YOOKASSA_ENABLED=false
YOOKASSA_SAFE_DEAL_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
