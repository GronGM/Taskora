APP_NAME=Taskora
APP_ENV=staging
APP_KEY=CHANGE_ME_GENERATE_ON_SERVER
APP_DEBUG=false
APP_URL=https://staging.таскора.рф

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

BETA_ACCESS_ENABLED=true
BETA_ACCESS_PASSWORD=CHANGE_ME
BETA_ACCESS_COOKIE_NAME=taskora_beta_access

TASKORA_PAYMENTS_MODE=stub
PAYMENT_PROVIDER=stub
PAYMENT_PROVIDER_MODE=stub

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=taskora_staging
DB_USERNAME=taskora
DB_PASSWORD=CHANGE_ME

CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
MAIL_MAILER=log
BROADCAST_CONNECTION=log

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

VITE_APP_NAME=Taskora
